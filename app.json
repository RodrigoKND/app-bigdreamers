{
  "expo": {
    "name": "Bigdreamerss",
    "slug": "bolt-expo-nativewind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "bigdreamerss",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bigdreamers",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/logo.png"
    },
    "android": {
      "package": "com.bigdreamers",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#1A3A5C"
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#1A3A5C"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraProguardRules": "-keep class com.bigdreamerss.** { *; }",
            "enableProguardInReleaseBuilds": true
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "La aplicación necesita acceder a tu galería para subir imágenes de perfil y comprobantes de pago.",
          "cameraPermission": "La aplicación necesita acceder a tu cámara para tomar fotos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#1A3A5C"
        }
      ],
      "expo-sharing",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "59c1d9fc-9f8e-44bb-bca6-a60028136f94"
      }
    },
    "owner": "bigdramers"
  }
}
